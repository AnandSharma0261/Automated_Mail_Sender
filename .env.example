# ── Gmail SMTP credentials ───────────────────────────────────────────────
# Use a Gmail "App Password" (NOT your normal password).
# Create one at: https://myaccount.google.com/apppasswords
EMAIL_USER=youraddress@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password

# ── Upstash Redis (for reliable scheduling on Vercel) ────────────────────
# Free database at: https://console.upstash.com  → create a Redis DB → REST API
# If these are left empty, the app falls back to an in-memory store
# (fine for local dev, but schedules will NOT survive on Vercel serverless).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cron security ────────────────────────────────────────────────────────
# A secret string. The /api/cron endpoint only runs when called with this.
# Set the same value in Vercel env vars and in your cron-job.org request header.
CRON_SECRET=change-me-to-a-long-random-string
